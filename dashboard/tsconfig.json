{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/hotkeys-catalog": ["../src/utils/hotkeysCatalog.ts"],
      "@shared/view-prefs-schema": ["../src/utils/view-prefs-schema.ts"],
      "@shared/saved-views-schema": ["../src/utils/saved-views-schema.ts"],
      "@shared/usage-filters": ["../src/utils/usage-filters.ts"],
      "@shared/saved-view-builder": ["../src/utils/saved-view-builder.ts"],
      "@shared/agents-schema": ["../src/utils/agents-schema.ts"],
      "@shared/terminal-schema": ["../src/utils/terminal-schema.ts"],
      "@shared/branch-name": ["../src/utils/branch-name.ts"],
      "@shared/todo-sections": ["../src/utils/todoSections.ts"],
      "@shared/workspace-visibility-schema": ["../src/utils/workspace-visibility-schema.ts"],
      "@shared/fact-registry": ["../src/utils/fact-registry.ts"],
      "@shared/view-filters-query": ["../src/utils/view-filters-query.ts"],
      "@shared/query": ["../src/utils/query/index.ts"],
      "@shared/derive-config": ["../src/utils/derive-config.ts"],
      "@shared/derive": ["../src/lifecycle/derive.ts"],
      "@shared/state-machine": ["../src/lifecycle/state-machine.ts"]
    }
  },
  "include": [
    "src",
    "../src/utils/hotkeysCatalog.ts",
    "../src/utils/view-prefs-schema.ts",
    "../src/utils/saved-views-schema.ts",
    "../src/utils/usage-filters.ts",
    "../src/utils/saved-view-builder.ts",
    "../src/utils/agents-schema.ts",
    "../src/utils/terminal-schema.ts",
    "../src/utils/branch-name.ts",
    "../src/utils/todoSections.ts",
    "../src/utils/workspace-visibility-schema.ts",
    "../src/utils/fact-registry.ts",
    "../src/utils/view-filters-query.ts",
    "../src/utils/query/index.ts",
    "../src/utils/query/ast.ts",
    "../src/utils/query/evaluate.ts",
    "../src/utils/query/fields.ts",
    "../src/utils/query/lexer.ts",
    "../src/utils/query/parser.ts",
    "../src/todos/types.ts",
    "../src/utils/derive-config.ts",
    "../src/lifecycle/derive.ts",
    "../src/lifecycle/state-machine.ts",
    "../src/lifecycle/types.ts"
  ]
}
