{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/hotkeys-catalog": ["../src/utils/hotkeysCatalog.ts"],
      "@shared/view-prefs-schema": ["../src/utils/view-prefs-schema.ts"],
      "@shared/agents-schema": ["../src/utils/agents-schema.ts"],
      "@shared/terminal-schema": ["../src/utils/terminal-schema.ts"]
    }
  },
  "include": [
    "src",
    "../src/utils/hotkeysCatalog.ts",
    "../src/utils/view-prefs-schema.ts",
    "../src/utils/agents-schema.ts",
    "../src/utils/terminal-schema.ts"
  ]
}
